{
  "name": "infra",
  "version": "0.1.0",
  "bin": {
    "infra": "bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "seed:dynamodb": "ts-node scripts/seed-app-table.ts",
    "deploy": "cdk deploy DeployWebAppLearningStack",
    "deploy:import": "cdk deploy ImportServiceStack",
    "deploy:product": "cdk deploy ProductServiceStack",
    "deploy:all": "cdk deploy --all",
    "diff:product": "cdk diff ProductServiceStack"
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1118.0",
    "jest": "^30",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1042.0",
    "@aws-sdk/lib-dynamodb": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "aws-cdk-lib": "^2.248.0",
    "constructs": "^10.5.0",
    "csv-parser": "^3.2.0"
  }
}
